    print("-"*70)

    metrics_order = ['RMSE', 'MSE', 'MAE', 'MAPE (%)', 'R²',
                    'Directional Accuracy (%)', 'Theil\'s U', 'MASE']

    for metric in metrics_order:
        lstm_val = lstm_metrics.get(metric, np.nan)
        nbeats_val = nbeats_metrics.get(metric, np.nan)

        # Format based on metric type
        if '(%)' in metric or metric == 'R²':
            if isinstance(lstm_val, (int, float)) and not np.isnan(lstm_val):
                lstm_str = f"{lstm_val:.2f}%" if '%' in metric else f"{lstm_val:.4f}"
            else:
                lstm_str = "N/A"

            if isinstance(nbeats_val, (int, float)) and not np.isnan(nbeats_val):
                nbeats_str = f"{nbeats_val:.2f}%" if '%' in metric else f"{nbeats_val:.4f}"
            else:
                nbeats_str = "N/A"
        else:
            if isinstance(lstm_val, (int, float)) and not np.isnan(lstm_val):
                lstm_str = f"{lstm_val:.4f}"
            else:
                lstm_str = "N/A"

            if isinstance(nbeats_val, (int, float)) and not np.isnan(nbeats_val):
                nbeats_str = f"{nbeats_val:.4f}"
            else:
                nbeats_str = "N/A"

        print(f"{metric:<25} {lstm_str:<20} {nbeats_str:<20}")

    # Determine which model is better for each metric
    print("\n" + "="*70)
    print("MODEL COMPARISON SUMMARY")
    print("="*70)

    # Lower is better for these metrics
