from darts.models import NBEATSModel
import torch

print("\n" + "="*50)
print("TRAINING N-BEATS MODEL")
print("="*50)

def train_nbeats_model(train_series, val_series=None, input_chunk_length=60, forecast_horizon=30, epochs=50):
    """
    Train N-BEATS model
    """
    # Set random seeds for reproducibility
    torch.manual_seed(42)
    np.random.seed(42)

    print("\nInitializing N-BEATS Model...")
    # Define model with simpler configuration for faster training
    model = NBEATSModel(
        input_chunk_length=input_chunk_length,
        output_chunk_length=forecast_horizon,
        generic_architecture=True,
        num_stacks=5,  # Reduced from 10 for faster training
        num_blocks=1,
        num_layers=3,  # Reduced from 4
        layer_widths=128,  # Reduced from 256
        n_epochs=epochs,
        nr_epochs_val_period=1,
        batch_size=32,
        optimizer_kwargs={'lr': 1e-3},
        model_name='NBEATS_HDFC',
        log_tensorboard=False,
        force_reset=True,
        save_checkpoints=True,
        random_state=42,
        pl_trainer_kwargs={
            'accelerator': 'gpu' if torch.cuda.is_available() else 'cpu',
            'devices': 1,
            'max_epochs': epochs
        }
    )

    print(f"Model type: {type(model)}")
    print(f"Input chunk length: {input_chunk_length}")
    print(f"Output chunk length: {forecast_horizon}")

    # Train model
    print("\nTraining N-BEATS Model...")
    try:
        if val_series is not None and len(val_series) > 0:
            print(f"Training with validation set ({len(val_series)} points)")
            model.fit(train_series, val_series=val_series, verbose=True)
        else:
            print(f"Training without validation set")
            model.fit(train_series, verbose=True)
    except Exception as e:
        print(f"Warning during training: {e}")
        print("Continuing with model as is...")

    return model

# Split validation set from training
