def calculate_residuals(actual, predicted):
    """
    Calculate model residuals
    """
    # Ensure same length
    min_len = min(len(actual), len(predicted))
    actual = actual[:min_len]
    predicted = predicted[:min_len]

    residuals = actual - predicted
    return residuals

def ljung_box_test(residuals, lags=20):
    """
    Perform Ljung-Box test for autocorrelation
    """
    try:
        lb_test = acorr_ljungbox(residuals, lags=[lags], return_df=True)
        return lb_test
    except:
        # Fallback calculation
        n = len(residuals)
        if n > lags:
            acf = np.correlate(residuals, residuals, mode='full')[n-1:] / n
            acf = acf[:lags+1]

            q_stat = n * (n + 2) * np.sum([acf[k]**2 / (n - k) for k in range(1, lags+1)])

            # Create a simple dataframe
            import pandas as pd
            return pd.DataFrame({
                'lb_stat': [q_stat],
                'lb_pvalue': [1 - scipy_stats.chi2.cdf(q_stat, lags)]
            })
        else:
            return pd.DataFrame({
                'lb_stat': [np.nan],
                'lb_pvalue': [np.nan]
            })

def jarque_bera_test(residuals):
    """
    Perform Jarque-Bera test for normality
    """
    if len(residuals) > 0:
        jb_stat, jb_pvalue = scipy_stats.jarque_bera(residuals)
        return jb_stat, jb_pvalue
    else:
        return np.nan, np.nan

