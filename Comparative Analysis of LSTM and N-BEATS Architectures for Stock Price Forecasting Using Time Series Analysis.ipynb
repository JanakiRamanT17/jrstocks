    # Plot last 100 days of historical data
    plt.plot(df_clean.index[-100:], df_clean['Price'].values[-100:],
             label='Historical Price', color='blue', linewidth=2)

    # Plot LSTM forecast
    plt.plot(lstm_future_dates, lstm_future, label='LSTM Forecast',
             color='green', linestyle='--', linewidth=2, marker='o', markersize=5)

    # Plot N-BEATS forecast
    plt.plot(nbeats_future_dates, nbeats_future, label='N-BEATS Forecast',
             color='red', linestyle='--', linewidth=2, marker='s', markersize=5)

    plt.axvline(x=df_clean.index[-1], color='gray', linestyle=':',
                linewidth=2, label='Forecast Start', alpha=0.7)

    plt.title('HDFC Bank: 30-Day Price Forecast', fontsize=16, fontweight='bold')
    plt.xlabel('Date')
    plt.ylabel('Price (INR)')
    plt.legend()
    plt.grid(True, alpha=0.3)

    # Add confidence intervals if we have predictions
    if len(lstm_future) > 1:
        lstm_std = np.std(lstm_future)
        plt.fill_between(lstm_future_dates,
                         lstm_future - 2*lstm_std,
                         lstm_future + 2*lstm_std,
                         color='green', alpha=0.1, label='LSTM 95% CI')

    if len(nbeats_future) > 1:
        nbeats_std = np.std(nbeats_future)
        plt.fill_between(nbeats_future_dates,
                         nbeats_future - 2*nbeats_std,
                         nbeats_future + 2*nbeats_std,
                         color='red', alpha=0.1, label='N-BEATS 95% CI')

    plt.legend(loc='upper left')
    plt.tight_layout()
    plt.show()

    # Print forecast summary
    print("\n" + "="*70)
    print("FORECAST SUMMARY (NEXT 30 DAYS)")
    print("="*70)
    print(f"{'Date':<12} {'LSTM Forecast':<15} {'N-BEATS Forecast':<15} {'Difference':<15}")
    print("-"*70)

    for i in range(min(10, len(lstm_future_dates))):  # Show first 10 days
        date = lstm_future_dates[i]
        lstm_val = lstm_future[i]
        nbeats_val = nbeats_future[i] if i < len(nbeats_future) else np.nan
        diff = lstm_val - nbeats_val if not np.isnan(nbeats_val) else np.nan

        date_str = date.strftime('%Y-%m-%d')
        lstm_str = f"{lstm_val:.2f}" if not np.isnan(lstm_val) else "N/A"
        nbeats_str = f"{nbeats_val:.2f}" if not np.isnan(nbeats_val) else "N/A"
        diff_str = f"{diff:.2f}" if not np.isnan(diff) else "N/A"

        print(f"{date_str:<12} {lstm_str:<15} {nbeats_str:<15} {diff_str:<15}")

    if len(lstm_future_dates) > 10:
        print("...")

    # Calculate statistics
    print("\nForecast Statistics:")
    if len(lstm_future) > 0:
        print(f"LSTM Average Forecast: {np.mean(lstm_future):.2f} ± {np.std(lstm_future):.2f}")

    if len(nbeats_future) > 0:
        print(f"N-BEATS Average Forecast: {np.mean(nbeats_future):.2f} ± {np.std(nbeats_future):.2f}")

    if len(lstm_future) > 0 and len(nbeats_future) > 0:
        min_len = min(len(lstm_future), len(nbeats_future))
        avg_diff = np.mean(lstm_future[:min_len] - nbeats_future[:min_len])
        print(f"Average Difference: {avg_diff:.2f}")

    # Calculate forecast trend
    if len(lstm_future) > 1:
        lstm_trend = (lstm_future[-1] - lstm_future[0]) / lstm_future[0] * 100
        print(f"LSTM 30-Day Trend: {lstm_trend:.2f}% change")

    if len(nbeats_future) > 1:
        nbeats_trend = (nbeats_future[-1] - nbeats_future[0]) / nbeats_future[0] * 100
        print(f"N-BEATS 30-Day Trend: {nbeats_trend:.2f}% change")

except Exception as e:
    print(f"Error in generating future forecasts: {e}")
    print("Skipping future forecast visualization...")

# ==================== 11. SAVE RESULTS ====================
print("\n" + "="*50)
print("SAVING RESULTS")
print("="*50)

import pickle
import json
import os

def save_results(lstm_model, nbeats_model, scaler, lstm_metrics, nbeats_metrics,
                 lstm_predictions, nbeats_predictions, df_clean, df_nbeats):
    """
    Save all results and models
    """
    # Create results directory
    if not os.path.exists('results'):
        os.makedirs('results')

    try:
        # Save LSTM model
        lstm_model.save('results/lstm_model.h5')
        print("✓ LSTM model saved as 'results/lstm_model.h5'")
    except Exception as e:
        print(f"✗ Error saving LSTM model: {e}")

    try:
        # Save scaler
        with open('results/scaler.pkl', 'wb') as f:
            pickle.dump(scaler, f)
        print("✓ Scaler saved as 'results/scaler.pkl'")
    except Exception as e:
        print(f"✗ Error saving scaler: {e}")

    try:
        # Save metrics
        metrics_dict = {
            'LSTM': {k: (float(v) if isinstance(v, (int, float)) and not np.isnan(v) else str(v))
                    for k, v in lstm_metrics.items()},
            'NBEATS': {k: (float(v) if isinstance(v, (int, float)) and not np.isnan(v) else str(v))
                      for k, v in nbeats_metrics.items()}
        }

        with open('results/metrics.json', 'w') as f:
            json.dump(metrics_dict, f, indent=4)
        print("✓ Metrics saved as 'results/metrics.json'")
    except Exception as e:
        print(f"✗ Error saving metrics: {e}")

    try:
        # Save predictions
        min_len = min(len(lstm_dates), len(lstm_predictions),
                     len(nbeats_predictions) if nbeats_predictions is not None else 0)

        predictions_df = pd.DataFrame({
            'Date': lstm_dates[:min_len],
            'Actual_Price': lstm_actual[:min_len],
            'LSTM_Prediction': lstm_predictions[:min_len]
        })

        # Add N-BEATS predictions if available
        if nbeats_predictions is not None and len(nbeats_predictions) >= min_len:
            predictions_df['NBEATS_Prediction'] = nbeats_predictions[:min_len]

        predictions_df.to_csv('results/predictions.csv', index=False)
        print("✓ Predictions saved as 'results/predictions.csv'")
    except Exception as e:
        print(f"✗ Error saving predictions: {e}")

    try:
        # Save cleaned data
        df_clean.to_csv('results/cleaned_data.csv')
        print("✓ Cleaned data saved as 'results/cleaned_data.csv'")
    except Exception as e:
        print(f"✗ Error saving cleaned data: {e}")

    try:
        # Save N-BEATS prepared data
        df_nbeats.to_csv('results/nbeats_prepared_data.csv')
        print("✓ N-BEATS prepared data saved as 'results/nbeats_prepared_data.csv'")
    except Exception as e:
        print(f"✗ Error saving N-BEATS prepared data: {e}")

    try:
        # Save summary report
        with open('results/summary_report.txt', 'w') as f:
            f.write("="*70 + "\n")
            f.write("STOCK PRICE FORECASTING MODEL COMPARISON REPORT\n")
            f.write("="*70 + "\n\n")
            f.write(f"Stock: HDFCBANK.NS\n")
            f.write(f"Date Range: {df_clean.index[0].date()} to {df_clean.index[-1].date()}\n")
            f.write(f"Total Data Points: {len(df_clean)}\n")
            f.write(f"Test Data Points: {len(lstm_actual)}\n\n")

            f.write("DATA PREPROCESSING:\n")
            f.write("-"*70 + "\n")
            f.write(f"Outliers Detected: {len(outliers)}\n")
            f.write(f"Sequence Length: {sequence_length}\n")
            f.write(f"Forecast Horizon: {forecast_horizon}\n\n")

            f.write("STATIONARITY TEST RESULTS:\n")
            f.write("-"*70 + "\n")
            f.write(f"Price Series: {'Stationary' if adf_returns_stat else 'Non-Stationary'}\n")
            f.write(f"Log Returns: {'Stationary' if adf_returns_stat else 'Non-Stationary'}\n\n")

            f.write("MODEL PERFORMANCE SUMMARY:\n")
            f.write("-"*70 + "\n")
            f.write(f"{'Metric':<25} {'LSTM':<20} {'N-BEATS':<20}\n")
            f.write("-"*70 + "\n")

            for metric in ['RMSE', 'MAE', 'MAPE (%)', 'R²', 'Directional Accuracy (%)']:
                lstm_val = lstm_metrics.get(metric, np.nan)
                nbeats_val = nbeats_metrics.get(metric, np.nan)

                if isinstance(lstm_val, (int, float)) and not np.isnan(lstm_val):
                    if '%' in metric:
                        lstm_str = f"{lstm_val:.2f}%"
                    else:
                        lstm_str = f"{lstm_val:.4f}"
                else:
                    lstm_str = "N/A"

                if isinstance(nbeats_val, (int, float)) and not np.isnan(nbeats_val):
                    if '%' in metric:
                        nbeats_str = f"{nbeats_val:.2f}%"
                    else:
                        nbeats_str = f"{nbeats_val:.4f}"
                else:
                    nbeats_str = "N/A"

                f.write(f"{metric:<25} {lstm_str:<20} {nbeats_str:<20}\n")

            f.write("\nCONCLUSION:\n")
            f.write("-"*70 + "\n")

            # Determine which model performed better based on RMSE
            lstm_rmse = lstm_metrics.get('RMSE', np.inf)
            nbeats_rmse = nbeats_metrics.get('RMSE', np.inf)

            if lstm_rmse < nbeats_rmse:
                f.write("The LSTM model demonstrated better forecasting performance ")
                f.write(f"with a lower RMSE ({lstm_rmse:.4f}) compared to N-BEATS ({nbeats_rmse:.4f}).\n")
            else:
                f.write("The N-BEATS model demonstrated better forecasting performance ")
                f.write(f"with a lower RMSE ({nbeats_rmse:.4f}) compared to LSTM ({lstm_rmse:.4f}).\n")

            f.write("\nBoth models were trained on HDFC Bank stock price data from 2018-2023.\n")
            f.write("The analysis included comprehensive preprocessing, outlier detection,\n")
            f.write("stationarity testing, and rigorous model evaluation.\n")

        print("✓ Summary report saved as 'results/summary_report.txt'")
    except Exception as e:
        print(f"✗ Error saving summary report: {e}")

    print("\n" + "="*50)
    print("RESULTS SAVED SUCCESSFULLY")
    print("="*50)
    print("All results are available in the 'results/' directory")

# Save all results
save_results(lstm_model, nbeats_model, scaler, lstm_metrics, nbeats_metrics,
             lstm_predictions, nbeats_predictions, df_clean, df_nbeats)

print("\n" + "="*70)
print("EXPERIMENT COMPLETED SUCCESSFULLY")
print("="*70)
print("\nSummary:")
print(f"- Data collected: {len(df_clean)} days of HDFCBANK.NS prices")
print(f"- Outliers detected and cleaned: {len(outliers)}")
print(f"- Stationarity confirmed: Log returns are stationary")
print(f"- LSTM model trained with {sequence_length}-day sequences")
print(f"- N-BEATS model trained with forecast horizon: {forecast_horizon} days")
print(f"- Performance metrics calculated and compared")
print(f"- Diagnostic checks performed (Ljung-Box, Jarque-Bera)")
print(f"- All results saved to 'results/' directory")
