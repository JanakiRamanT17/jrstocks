def calculate_metrics(actual, predicted, model_name=""):
    """
    Calculate various accuracy metrics
    """
    # Ensure same length
    min_len = min(len(actual), len(predicted))
    if min_len == 0:
        print(f"✗ No data for {model_name} metrics calculation")
        return {}

    actual = actual[:min_len]
    predicted = predicted[:min_len]

    # Calculate basic metrics
    mse = np.mean((actual - predicted) ** 2)
    rmse = np.sqrt(mse)
    mae = np.mean(np.abs(actual - predicted))

    # MAPE (handle zero values)
    mask = actual != 0
    if mask.any():
        mape_val = np.mean(np.abs((actual[mask] - predicted[mask]) / actual[mask])) * 100
    else:
        mape_val = np.nan

    # Directional Accuracy
    if len(actual) > 1:
        actual_direction = np.diff(actual) > 0
        predicted_direction = np.diff(predicted) > 0
        directional_accuracy = np.mean(actual_direction == predicted_direction) * 100
    else:
        directional_accuracy = np.nan

    # R-squared
    ss_res = np.sum((actual - predicted) ** 2)
    ss_tot = np.sum((actual - np.mean(actual)) ** 2)
    r_squared = 1 - (ss_res / ss_tot) if ss_tot != 0 else 0

    # Theil's U Statistic
    if len(actual) > 1:
        naive_forecast = np.roll(actual, 1)
        naive_forecast[0] = actual[0]
        naive_mse = np.mean((actual - naive_forecast) ** 2)
        theil_u = rmse / np.sqrt(naive_mse) if naive_mse > 0 else np.nan
    else:
        theil_u = np.nan

    # Mean Absolute Scaled Error (MASE)
    if len(actual) > 1:
        naive_error = np.mean(np.abs(np.diff(actual)))
        mase = mae / naive_error if naive_error != 0 else np.nan
    else:
        mase = np.nan

    metrics = {
        'RMSE': rmse,
        'MSE': mse,
        'MAE': mae,
        'MAPE (%)': mape_val,
        'Directional Accuracy (%)': directional_accuracy,
        'R²': r_squared,
        'Theil\'s U': theil_u,
        'MASE': mase
    }

    return metrics

def print_metrics_table(lstm_metrics, nbeats_metrics):
    """
    Print metrics in a formatted table
    """
    print("\n" + "="*70)
    print("MODEL PERFORMANCE COMPARISON")
